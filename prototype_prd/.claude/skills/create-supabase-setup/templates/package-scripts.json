{
  "//": "Merge the `scripts` block below into your package.json. These wrap the most common Supabase loops so you (and Claude Code) can run short, memorable commands.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",

    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:new": "supabase migration new",
    "db:diff": "supabase db diff -f",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > src/lib/database.types.ts",

    "supabase:link": "supabase link --project-ref",
    "supabase:types:remote": "supabase gen types typescript --linked > src/lib/database.types.ts",

    "setup": "supabase start && supabase db reset && npm run db:types"
  }
}
