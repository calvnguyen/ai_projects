# =============================================================================
# Supabase environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values.
#   cp .env.example .env.local
#
# `.env.local` is git-ignored by Next.js. NEVER commit real keys.
# Get local values by running `supabase status` after `supabase start`.
# =============================================================================

# --- PUBLIC (safe to expose to the browser) ----------------------------------
# These are prefixed NEXT_PUBLIC_ and are bundled into client-side JS.
# The anon key is meant to be public — it only grants access allowed by RLS.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key-from-supabase-status

# --- SECRET (server-side only — NEVER prefix with NEXT_PUBLIC_) ---------------
# The service_role key BYPASSES Row Level Security. Treat it like a root password.
# Only read it in server code (Server Components, Route Handlers, Server Actions,
# cron jobs). If this ever lands in the browser bundle, rotate it immediately.

SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key-from-supabase-status

# Direct Postgres connection (server-side migrations/scripts/ORMs only)
# Local default:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- PRODUCTION (hosted Supabase) --------------------------------------------
# In production, set these in your host's dashboard (Vercel/Fly/Railway),
# NOT in a committed file. Values come from the Supabase dashboard:
#   Project Settings → API.
#
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<prod-anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<prod-service-role-key>

# --- OPTIONAL: third-party / app config --------------------------------------
# SITE_URL is used to build auth redirect URLs (email confirmations, OAuth).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OAuth provider secrets (server-side), if you enable social login:
# SUPABASE_AUTH_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_GOOGLE_SECRET=
